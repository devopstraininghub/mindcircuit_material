  name: with-resources
spec:
  containers:
    - name: web
      image: nginx:latest
      resources:
        requests:
          cpu: "200m"     # needs at least 0.2 of a CPU core
          memory: "256Mi" # needs at least 256 MB of RAM
        limits:
